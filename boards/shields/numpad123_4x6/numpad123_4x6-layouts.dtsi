#include <physical_layouts.dtsi>

/ {
    physical_layout_numpad123_4x6: physical_layout_numpad123_4x6 {
        compatible = "zmk,physical-layout";
        display-name = "numpad123-4x6";
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100  300    0       0   300     0>
            , <&key_physical_attrs 100 100    0  100       0     0   100>
            , <&key_physical_attrs 100 100  100  100       0   100   100>
            , <&key_physical_attrs 100 100  200  100       0   200   100>
            , <&key_physical_attrs 100 100  300  100       0   300   100>
            , <&key_physical_attrs 100 100    0  200       0     0   200>
            , <&key_physical_attrs 100 100  100  200       0   100   200>
            , <&key_physical_attrs 100 100  200  200       0   200   200>
            , <&key_physical_attrs 100 100  300  200       0   300   200>
            , <&key_physical_attrs 100 100    0  300       0     0   300>
            , <&key_physical_attrs 100 100  100  300       0   100   300>
            , <&key_physical_attrs 100 100  200  300       0   200   300>
            , <&key_physical_attrs 100 100  300  300       0   300   300>
            , <&key_physical_attrs 100 100    0  400       0     0   400>
            , <&key_physical_attrs 100 100  100  400       0   100   400>
            , <&key_physical_attrs 100 100  200  400       0   200   400>
            , <&key_physical_attrs 100 100  300  400       0   300   400>
            , <&key_physical_attrs 100 100    0  500       0     0   500>
            , <&key_physical_attrs 100 100  100  500       0   100   500>
            , <&key_physical_attrs 100 100  200  500       0   200   500>
            , <&key_physical_attrs 100 100  300  500       0   300   500>
            , <&key_physical_attrs 100 100    0  600       0     0   600>
            , <&key_physical_attrs 100 100  100  600       0   100   600>
            , <&key_physical_attrs 100 100  200  600       0   200   600>
            , <&key_physical_attrs 100 100  300  600       0   300   600>
            ;
    };
};
